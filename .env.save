APP_DEBUG=true
APP_URL=https://portal.mcintoshcleaningservice.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ==============================
# DATABASE (DISABLED FOR NOW)
# ==============================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=clientops
DB_USERNAME=admin
DB_PASSWORD=YOUR_DB_PASSWORD

# ==============================
# CACHE / SESSIONS (FILE-BASED)
# ==============================
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_CONNECTION=null
SESSION_LIFETIME=120

QUEUE_CONNECTION=sync

# ==============================
# FILES
# ==============================
FILESYSTEM_DISK=local

# ==============================
# MAIL (TEMP – LOG MODE)
# ==============================
MAIL_MAILER=log
MAIL_FROM_ADDRESS=sales@mcintoshcleaningservice.com
MAIL_FROM_NAME="McIntosh Cleaning Service"

# ==============================
# DISABLE UNUSED SERVICES
# ==============================
REDIS_CLIENT=null
MEMCACHED_HOST=null
