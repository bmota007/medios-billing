        ->paginate(15);

    return view('invoice.history', compact('invoices'));
}
public function markPaid(Request $request, Invoice $invoice)
{
    $request->validate([
        'payment_method' => 'required|string',
        'check_number' => 'nullable|string'
    ]);

    if ($request->payment_method === 'check' && empty($request->check_number)) {
        return back()->withErrors([
            'check_number' => 'Check number is required when payment method is check.'
        ]);
    }

    $invoice->update([
        'status' => 'paid',
        'paid_at' => now(),
        'payment_method' => $request->payment_method,
        'check_number' => $request->check_number,
    ]);

    // Optional: send receipt email
    Mail::to($invoice->customer_email)->send(
        new \App\Mail\InvoicePaidMail($invoice)
    );

    return back()->with('success', 'Invoice marked as paid.');
}
public function view(Invoice $invoice)
{
    // Calculate subtotal from items
    $sub_total = 0;

    if (is_array($invoice->items)) {
        foreach ($invoice->items as $item) {
            $sub_total += $item['line_total'] ?? 0;
        }
    }

    $grand_total = $invoice->total;

    $data = [
        'customer_name'    => $invoice->customer_name,
        'customer_email'   => $invoice->customer_email,
        'street_address'   => $invoice->street_address,
        'city_state_zip'   => $invoice->city_state_zip,
        'invoice_date'     => $invoice->invoice_date,
        'due_date'         => $invoice->due_date,
        'notes'            => $invoice->notes,
        'items'            => $invoice->items,
        'invoice_no'       => $invoice->invoice_no,
        'sub_total'        => $sub_total,
        'grand_total'      => $grand_total,
    ];

    $pdf = Pdf::loadView('pdf.invoice', $data);
    $pdf_base64 = base64_encode($pdf->output());

    return view('invoice.preview', array_merge($data, [
        'pdf_base64' => $pdf_base64,
        'total'      => $invoice->total,
        'sent_at'    => $invoice->sent_at,
        'status'     => $invoice->status,
        'paid_at'    => $invoice->paid_at,
    ]));
}
