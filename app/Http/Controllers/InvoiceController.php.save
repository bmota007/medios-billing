<?php

namespace App\Http\Controllers;

use App\Models\Invoice;
use Illuminate\Http\Request;
use Barryvdh\DomPDF\Facade\Pdf;
use Illuminate\Support\Facades\Mail;
use Illuminate\Support\Facades\Log;
use Carbon\Carbon;

class InvoiceController extends Controller
{
    /* =========================
       SHOW FORM (ADMIN)
    ========================= */

public function showForm(Request $request)
{
    $customers = \App\Models\Customer::orderBy('name')->get();

    $selectedCustomer = null;
    if ($request->filled('customer_id')) {
        $selectedCustomer = \App\Models\Customer::find($request->customer_id);
    }

    return view('invoice_form', compact('customers', 'selectedCustomer'));
}
    /* =========================
       PAYMENT PAGE (PUBLIC)
       /payments?invoice=INV-XXXX
    ========================= */
    public function paymentPage(Request $request)
    {
        $invoiceNo = $request->query('invoice');
        if (!$invoiceNo) {
            abort(404);
        }

        $invoice = Invoice::where('invoice_no', $invoiceNo)->firstOrFail();

        return view('invoice.payment', compact('invoice'));
    }

    /* =========================
       STRIPE CHECKOUT
    ========================= */
    public function checkout(Request $request)
    {
        $request->validate([
            'invoice_id' => 'required|integer',
        ]);

        $invoice = Invoice::findOrFail($request->invoice_id);

        if ($invoice->status === 'paid') {
            return redirect()
                ->route('invoice.payment.page', ['invoice' => $invoice->invoice_no])
                ->with('success', 'Invoice already paid.');
        }

        \Stripe\Stripe::setApiKey(config('services.stripe.secret'));

        $session = \Stripe\Checkout\Session::create([
            'payment_method_types' => ['card'],
            'mode' => 'payment',
            'line_items' => [[
                'price_data' => [
                    'currency' => 'usd',
                    'product_data' => [
                        'name' => 'Invoice ' . $invoice->invoice_no,
                    ],
                    'unit_amount' => (int) round(((float)$invoice->total) * 100),
                ],
                'quantity' => 1,
            ]],
            'metadata' => [
                'invoice_no' => $invoice->invoice_no,
            ],
            'success_url' => route('invoice.payment.success') . '?session_id={CHECKOUT_SESSION_ID}',
            'cancel_url'  => route('invoice.payment.page', ['invoice' => $invoice->invoice_no]),
        ]);

        return redirect($session->url);
    }

    /* =========================
       SUCCESS PAGE
    ========================= */
    public function success()
    {
        return view('invoice.payment-success');
    }

    /* =========================
       PREVIEW INVOICE (ADMIN)
    ========================= */
    public function preview(Request $request)
    {
        $data = $this->buildInvoiceData($request);

        $data['invoice_date'] = Carbon::parse($data['invoice_date'])->format('m/d/Y');
        $data['due_date']     = Carbon::parse($data['due_date'])->format('m/d/Y');

        // Limit notes length to prevent second page overflow
        $data['notes'] = $this->limitNotes($data['notes'] ?? '');

        $pdf = Pdf::loadView('pdf.invoice', $data);
        $data['pdf_base64'] = base64_encode($pdf->output());

        return view('invoice.preview', $data);
    }

    /* =========================
       SAVE + SEND INVOICE
    ========================= */
    public function send(Request $request)
    {
        $data = $this->buildInvoiceData($request);

        // store same notes (full), but PDF display gets limited in preview/view
        $invoice = Invoice::create([
            'invoice_no'      => $data['invoice_no'],
            'customer_name'   => $data['customer_name'],
            'customer_email'  => $data['customer_email'],
            'street_address'  => $data['street_address'],
            'city_state_zip'  => $data['city_state_zip'],
            'invoice_date'    => $data['invoice_date'],
            'due_date'        => $data['due_date'],
            'total'           => $data['grand_total'],
            'notes'           => $data['notes'],
            'items'           => $data['items'],
            'sent_at'         => now(),
            'status'          => 'unpaid',
        ]);

        $pdf = Pdf::loadView('pdf.invoice', [
            ...$data,
            'notes' => $this->limitNotes($data['notes'] ?? ''),
        ]);

        $this->emailInvoice($invoice, $pdf, false);

        return redirect()
            ->route('invoice.history')
            ->with('success', 'Invoice sent and saved.');
    }

    /* =========================
       HISTORY (ADMIN)
    ========================= */
    public function history()
    {
        $invoices = Invoice::orderByDesc('created_at')->paginate(20);
        return view('invoice.history', compact('invoices'));
    }

    /* =========================
       RESEND INVOICE (ADMIN)
       Prevent resending PAID
    ========================= */
    public function resend(Invoice $invoice)
    {
        if ($invoice->status === 'paid') {
            return redirect()
                ->route('invoice.history')
                ->with('error', 'Paid invoices cannot be resent.');
        }

        $items = $this->normalizeItems($invoice->items);

        // note: subtotal should be computed from items if possible
        $subTotal = 0;
        foreach ($items as $item) {
            $subTotal += (float) ($item['line_total'] ?? (($item['qty'] ?? 0) * ($item['price'] ?? 0)));
        }
        if ($subTotal <= 0) {
            $subTotal = (float) $invoice->total;
        }

        $notesLimited = $this->limitNotes($invoice->notes ?? '');

        $pdf = Pdf::loadView('pdf.invoice', [
            'invoice_no'     => $invoice->invoice_no,
            'customer_name'  => $invoice->customer_name,
            'customer_email' => $invoice->customer_email,
            'street_address' => $invoice->street_address,
            'city_state_zip' => $invoice->city_state_zip,
            'invoice_date'   => optional($invoice->invoice_date)->format('m/d/Y'),
            'due_date'       => optional($invoice->due_date)->format('m/d/Y'),
            'items'          => $items,
            'sub_total'      => $subTotal,
            'tax_fee'        => 0,
            'grand_total'    => (float) $invoice->total,
            'notes'          => $notesLimited,
            'status'         => $invoice->status,
        ]);

        $this->emailInvoice($invoice, $pdf, true);

        $invoice->sent_at = now();
        $invoice->save();

        return redirect()
            ->route('invoice.history')
            ->with('success', 'Invoice resent successfully.');
    }

    /* =========================
       VIEW PDF (ADMIN)
    ========================= */
    public function view(Invoice $invoice)
    {
        $items = $this->normalizeItems($invoice->items);

        $subTotal = 0;
        foreach ($items as $item) {
            $subTotal += (float) ($item['line_total'] ?? (($item['qty'] ?? 0) * ($item['price'] ?? 0)));
        }

        $notesLimited = $this->limitNotes($invoice->notes ?? '');

        $pdf = Pdf::loadView('pdf.invoice', [
            'invoice_no'     => $invoice->invoice_no,
            'customer_name'  => $invoice->customer_name,
            'customer_email' => $invoice->customer_email,
            'street_address' => $invoice->street_address,
            'city_state_zip' => $invoice->city_state_zip,
            'invoice_date'   => optional($invoice->invoice_date)->format('m/d/Y'),
            'due_date'       => optional($invoice->due_date)->format('m/d/Y'),
            'items'          => $items,
            'sub_total'      => $subTotal,
            'tax_fee'        => 0,
            'grand_total'    => (float) $invoice->total,
            'notes'          => $notesLimited,
            'status'         => $invoice->status,
        ]);

        return $pdf->stream('invoice-' . $invoice->invoice_no . '.pdf');
    }

    /* =========================
       MANUAL MARK PAID (ZELLE/CASH)
       POST /invoice/{invoice}/mark-paid
       Auth-protected route
    ========================= */
    public function markPaid(Invoice $invoice)
    {
        if ($invoice->status === 'paid') {
            return redirect()
                ->route('invoice.history')
                ->with('error', 'Invoice already marked as paid.');
        }

        $invoice->status  = 'paid';
        $invoice->paid_at = now();
        $invoice->save();

        return redirect()
            ->route('invoice.history')
            ->with('success', 'Invoice marked as PAID manually.');
    }

    /* =========================
       STRIPE WEBHOOK
       POST /stripe/webhook
    ========================= */
    public function stripeWebhook(Request $request)
    {
        \Stripe\Stripe::setApiKey(config('services.stripe.secret'));

        $payload = $request->getContent();
        $sigHeader = $request->header('Stripe-Signature');
        $endpointSecret = env('STRIPE_WEBHOOK_SECRET');

        try {
            $event = \Stripe\Webhook::constructEvent($payload, $sigHeader, $endpointSecret);
        } catch (\Throwable $e) {
            Log::error('Stripe signature failed', ['error' => $e->getMessage()]);
            return response('Invalid signature', 400);
        }

        if ($event->type === 'checkout.session.completed') {
            $session = $event->data->object;
            $invoiceNo = $session->metadata->invoice_no ?? null;

            if (!$invoiceNo) {
                Log::warning('Webhook missing invoice_no metadata');
                return response('Missing metadata', 200);
            }

            $invoice = Invoice::where('invoice_no', $invoiceNo)->first();

            if ($invoice && $invoice->status !== 'paid') {
                $invoice->status = 'paid';
                $invoice->paid_at = now();
                $invoice->save();

                Log::info('Invoice marked paid', ['invoice' => $invoiceNo]);
            }
        }

        return response('Webhook handled', 200);
    }

/* =========================
   ADMIN DASHBOARD
========================= */
public function adminDashboard()
{
    $totalRevenue = Invoice::where('status', 'paid')->sum('total');

    $thisMonthRevenue = Invoice::where('status', 'paid')
        ->whereMonth('paid_at', now()->month)
        ->whereYear('paid_at', now()->year)
        ->sum('total');

    $paidCount = Invoice::where('status', 'paid')->count();
    $unpaidCount = Invoice::where('status', 'unpaid')->count();

    $outstandingBalance = Invoice::where('status', 'unpaid')->sum('total');

    $recentPayments = Invoice::where('status', 'paid')
        ->orderByDesc('paid_at')
        ->take(5)
        ->get();

    // Monthly revenue chart data
    $monthlyData = Invoice::where('status', 'paid')
        ->whereYear('paid_at', now()->year)
        ->selectRaw('MONTH(paid_at) as month, SUM(total) as total')
        ->groupBy('month')
        ->pluck('total', 'month');

    return view('invoice.dashboard', compact(
        'totalRevenue',
        'thisMonthRevenue',
        'paidCount',
        'unpaidCount',
        'outstandingBalance',
        'recentPayments',
        'monthlyData'
    ));
}

/* =========================
   CREATE INVOICE (LOAD BUILDER)
========================= */
public function createInvoice(Request $request)
{
    $customer = null;

    if ($request->customer_id) {
        $customer = \App\Models\Customer::find($request->customer_id);
    }

    return view('invoice_builder', compact('customer'));
}

    /* =========================
       BUILD INVOICE DATA
    ========================= */
    private function buildInvoiceData(Request $request): array
    {
        $request->validate([
            'customer_name'  => 'required|string|max:255',
            'customer_email' => 'required|email|max:255',
            'street_address' => 'required|string|max:255',
            'city_state_zip' => 'required|string|max:255',
            'invoice_date'   => 'required|date',
            'due_date'       => 'required|date',
            'items'          => 'required|array|min:1',
            'items.*.desc'   => 'required|string',
            'items.*.qty'    => 'required|integer|min:1',
            'items.*.price'  => 'required|numeric',
        ]);

        $items = [];
        $subTotal = 0;

        foreach ($request->items as $it) {
            $qty = (int) ($it['qty'] ?? 0);
            $price = (float) ($it['price'] ?? 0);
            $desc = (string) ($it['desc'] ?? '');

            $line = $qty * $price;

            $items[] = [
                'desc'       => $desc,
                'qty'        => $qty,
                'price'      => $price,
                'line_total' => $line,
            ];

            $subTotal += $line;
        }

        return [
            'invoice_no'     => 'INV-' . now()->format('Ymd-His'),
            'customer_name'  => $request->customer_name,
            'customer_email' => $request->customer_email,
            'street_address' => $request->street_address,
            'city_state_zip' => $request->city_state_zip,
            'invoice_date'   => $request->invoice_date,
            'due_date'       => $request->due_date,
            'items'          => $items,
            'sub_total'      => $subTotal,
            'tax_fee'        => 0,
            'grand_total'    => $subTotal,
            'notes'          => (string) ($request->notes ?? ''),
        ];
    }

    /* =========================
       HELPERS
    ========================= */
    private function normalizeItems($items): array
    {
        if (is_string($items)) {
            $decoded = json_decode($items, true);
            return is_array($decoded) ? $decoded : [];
        }

        return is_array($items) ? $items : [];
    }

    private function limitNotes(string $notes, int $maxCharacters = 320): string
    {
        $notes = trim($notes);

        if ($notes === '') {
            return '';
        }

        if (mb_strlen($notes) > $maxCharacters) {
            return mb_substr($notes, 0, $maxCharacters) . '...';
        }

        return $notes;
    }

    private function emailInvoice(Invoice $invoice, $pdf, bool $isResend): void
    {
        $paymentUrl = url('/payments?invoice=' . $invoice->invoice_no);

        $title = $isResend ? "Invoice {$invoice->invoice_no} (Reminder)" : "Invoice {$invoice->invoice_no}";
        $intro = $isResend
            ? "This is a reminder for your unpaid invoice."
            : "You have received a new invoice.";

        $html = "
            <h2>{$title}</h2>
            <p>{$intro}</p>
            <p><strong>Total Due:</strong> $" . number_format((float)$invoice->total, 2) . "</p>
            <p>
                <a href='{$paymentUrl}'
                   style='background:#0657bd;color:#ffffff;
                          padding:12px 20px;
                          text-decoration:none;
                          border-radius:4px;
                          display:inline-block;'>
                    Pay Now
                </a>
            </p>
            <p>{$paymentUrl}</p>
            <br>
            <p>Thank you for choosing McIntosh Cleaning Services.</p>
        ";

        Mail::send([], [], function ($message) use ($invoice, $pdf, $html, $isResend) {

            $subject = $isResend
                ? 'Invoice ' . $invoice->invoice_no . ' (Reminder)'
                : 'Invoice ' . $invoice->invoice_no;

            $message
                ->to($invoice->customer_email)
                ->cc('pattylmcintosh@yahoo.com')
                ->subject($subject)
                ->attachData(
                    $pdf->output(),
                    'invoice-' . $invoice->invoice_no . '.pdf',
                    ['mime' => 'application/pdf']
                )
                ->html($html);


});
}
/* =========================
   CUSTOMERS INDEX
========================= */
public function customersIndex(Request $request)
{
    $search = $request->query('search');

    $customers = \App\Models\Customer::when($search, function ($query) use ($search) {
        $query->where('name', 'like', "%{$search}%")
              ->orWhere('email', 'like', "%{$search}%")
              ->orWhere('phone', 'like', "%{$search}%");
    })
    ->orderByDesc('created_at')
    ->paginate(15);

    return view('customers.index', compact('customers'));
}

/* =========================
   CREATE CUSTOMER
========================= */
public function customersCreate()
{
    return view('customers.create');
}

/* =========================
   STORE CUSTOMER
========================= */
public function customersStore(Request $request)
{
    $request->validate([
        'name' => 'required|string|max:255',
        'email' => 'nullable|email|max:255',
        'phone' => 'nullable|string|max:255',
        'company_name' => 'nullable|string|max:255',
        'customer_type' => 'required|string|max:50',
        'city_state_zip' => 'nullable|string|max:255',
        'notes' => 'nullable|string',
    ]);

    // Extract city from combined field
    $city = null;
    $state = null;
    $zip = null;

    if ($request->city_state_zip) {
        $parts = explode(',', $request->city_state_zip);

        if (count($parts) > 0) {
            $city = trim($parts[0]);
        }
    }

    \App\Models\Customer::create([
        'name' => $request->name,
        'email' => $request->email,
        'phone' => $request->phone,
        'company_name' => $request->company_name,
        'customer_type' => $request->customer_type,
        'city' => $city,
        'state' => $state,
        'zip' => $zip,
        'country' => 'USA',
        'status' => 'lead',
        'notes' => $request->notes,
    ]);

    return redirect()
        ->route('customers.index')
        ->with('success', 'Customer created successfully.');
}

/* =========================
   EDIT CUSTOMER
========================= */
public function customersEdit(\App\Models\Customer $customer)
{
    return view('customers.edit', compact('customer'));
}

/* =========================
   UPDATE CUSTOMER
========================= */
public function customersUpdate(Request $request, \App\Models\Customer $customer)
{
    $request->validate([
        'name' => 'required|string|max:255',
        'email' => 'required|email|max:255',
        'phone' => 'nullable|string|max:255',
        'street_address' => 'required|string|max:255',
        'city_state_zip' => 'required|string|max:255',
    ]);

    $customer->update($request->all());

    return redirect()
        ->route('customers.index')
        ->with('success', 'Customer updated successfully.');
}
}
