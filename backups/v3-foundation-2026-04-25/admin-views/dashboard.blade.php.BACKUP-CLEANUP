<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    const revenueEl = document.getElementById('revenueChart');

    if (revenueEl) {
        const revenueCtx = revenueEl.getContext('2d');
        const revenueGradient = revenueCtx.createLinearGradient(0, 0, 0, 360);
        revenueGradient.addColorStop(0, 'rgba(124, 58, 237, 0.42)');
        revenueGradient.addColorStop(1, 'rgba(124, 58, 237, 0.02)');

        new Chart(revenueEl, {
            type: 'line',
            data: {
                labels: @json($monthLabels),
                datasets: [{
                    label: 'Revenue',
                    data: @json($monthlyRevenue),
                    borderColor: '#7c3aed',
                    backgroundColor: revenueGradient,
                    fill: true,
                    tension: 0.42,
                    borderWidth: 3,
                    pointRadius: 4,
                    pointHoverRadius: 7,
                    pointBackgroundColor: '#60a5fa',
                    pointBorderColor: '#c4b5fd',
                    pointBorderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: {
                    mode: 'index',
                    intersect: false
                },
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        backgroundColor: '#0f172a',
                        borderColor: 'rgba(255,255,255,.08)',
                        borderWidth: 1,
                        titleColor: '#fff',
                        bodyColor: '#cbd5e1',
                        displayColors: false,
                        callbacks: {
                            label: function(context) {
                                return '$' + Number(context.parsed.y).toLocaleString(undefined, {
                                    minimumFractionDigits: 2,
                                    maximumFractionDigits: 2
                                });
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        ticks: {
                            color: '#94a3b8'
                        },
                        grid: {
                            color: 'rgba(255,255,255,.035)'
                        },
                        border: {
                            display: false
                        }
                    },
                    y: {
                        beginAtZero: true,
                        ticks: {
                            color: '#94a3b8',
                            callback: function(value) {
                                return '$' + Number(value).toLocaleString();
                            }
                        },
                        grid: {
                            color: 'rgba(255,255,255,.045)'
                        },
                        border: {
                            display: false
                        }
                    }
                }
            }
        });
    }

    const subEl = document.getElementById('subscriptionChart');

    if (subEl) {
        new Chart(subEl, {
            type: 'doughnut',
            data: {
                labels: ['Active', 'Past Due', 'Trial', 'Cancelled'],
                datasets: [{
                    data: [
                        {{ $subscriptionStats['active'] ?? 0 }},
                        {{ $subscriptionStats['past_due'] ?? 0 }},
                        {{ $subscriptionStats['trial'] ?? 0 }},
                        {{ $subscriptionStats['cancelled'] ?? 0 }}
                    ],
                    backgroundColor: ['#22c55e', '#f59e0b', '#3b82f6', '#ef4444'],
                    borderWidth: 0,
                    hoverOffset: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                cutout: '72%',
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        backgroundColor: '#0f172a',
                        borderColor: 'rgba(255,255,255,.08)',
                        borderWidth: 1,
                        titleColor: '#fff',
                        bodyColor: '#cbd5e1'
                    }
                }
            }
        });
    }

    const sparkConfigs = [
        { id: 'sparkMrr', color: '#8b5cf6', fill: 'rgba(139,92,246,.18)', data: [9,14,12,11,13,15,14,12,13,16,17,20] },
        { id: 'sparkCompanies', color: '#3b82f6', fill: 'rgba(59,130,246,.16)', data: [4,5,5,6,5,7,8,8,9,10,10,11] },
        { id: 'sparkSubs', color: '#22c55e', fill: 'rgba(34,197,94,.16)', data: [18,22,21,24,28,26,30,33,31,36,34,39] },
        { id: 'sparkHealth', color: '#f59e0b', fill: 'rgba(245,158,11,.12)', data: [98,99,99,99,100,100,100,100,100,100,100,100] },
        { id: 'sparkRevenue', color: '#06b6d4', fill: 'rgba(6,182,212,.14)', data: [11,15,14,17,13,19,18,18,17,23,22,27] }
    ];

    sparkConfigs.forEach(function(item) {
        const el = document.getElementById(item.id);

        if (!el) return;

        const ctx = el.getContext('2d');
        const gradient = ctx.createLinearGradient(0, 0, 0, 56);
        gradient.addColorStop(0, item.fill);
        gradient.addColorStop(1, 'rgba(255,255,255,0)');

        new Chart(el, {
            type: 'line',
            data: {
                labels: item.data.map((_, i) => i + 1),
                datasets: [{
                    data: item.data,
                    borderColor: item.color,
                    backgroundColor: gradient,
                    fill: true,
                    tension: 0.45,
                    borderWidth: 2.5,
                    pointRadius: 0,
                    pointHoverRadius: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                animation: {
                    duration: 1400
                },
                plugins: {
                    legend: { display: false },
                    tooltip: { enabled: false }
                },
                scales: {
                    x: { display: false },
                    y: { display: false }
                }
            }
        });
    });
});
</script>
